<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- Top toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#CC0000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_alignParentTop="true">

        <!-- Hamburger menu button -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#FFFFFF"
            android:contentDescription="Menu" />

        <!-- App title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Emergency Mesh"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <!-- Connection status icon -->
        <TextView
            android:id="@+id/tvConnectionDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="#888888"
            android:layout_marginEnd="8dp" />

    </LinearLayout>

    <!-- Status bar -->
    <TextView
        android:id="@+id/tvPeerCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbar"
        android:background="#AA0000"
        android:gravity="center"
        android:padding="4dp"
        android:text="Starting mesh network..."
        android:textColor="#FFFFFF"
        android:textSize="11sp" />

    <!-- Slide-out drawer menu (hidden by default) -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="8dp"
        android:visibility="gone"
        android:padding="8dp">

        <!-- Find Peers -->
        <LinearLayout
            android:id="@+id/menuFindPeers"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#CC0000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find Peers"
                android:textColor="#333333"
                android:textSize="16sp"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- Contacts -->
        <LinearLayout
            android:id="@+id/menuContacts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#CC0000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Contacts"
                android:textColor="#333333"
                android:textSize="16sp"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/menuProfile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="#CC0000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Profile"
                android:textColor="#333333"
                android:textSize="16sp"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- Clear Messages -->
        <LinearLayout
            android:id="@+id/menuClearMessages"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#CC0000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear Messages"
                android:textColor="#333333"
                android:textSize="16sp"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- Connection info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:background="#FFF5F5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Network Status"
                android:textColor="#CC0000"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMenuStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Initializing..."
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Overlay to close drawer when clicking outside -->
    <View
        android:id="@+id/drawerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone"
        android:layout_below="@id/toolbar" />

    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvPeerCount"
        android:layout_above="@id/bottomLayout"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Bottom section -->
    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:layout_alignParentBottom="true">

        <!-- SOS Button -->
        <Button
            android:id="@+id/btnSos"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FF0000"
            android:text="🆘 SOS EMERGENCY ALERT"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="6dp" />

        <!-- Message input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Type a message..."
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:background="#EEEEEE"
                android:padding="10dp"
                android:maxLines="3"
                android:inputType="text"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#CC0000"
                android:text="Send"
                android:textColor="#FFFFFF"
                android:padding="10dp" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>